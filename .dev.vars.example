# Supabase project (eu-west-2)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct connection (for Drizzle migrations + local scripts). Port 5432.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Pooler connection (for runtime queries from edge). Port 6543, transaction mode.
DATABASE_URL_POOLED=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-west-2.pooler.supabase.com:6543/postgres

# Paystack (Phase G — leave blank for now)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Admin bootstrap (D-105). Email that auto-grants admin on signup/signin.
ADMIN_BOOTSTRAP_EMAIL=

# D-120 registered payment details. Base64-encoded 32-byte (AES-256) key.
# Generate with: openssl rand -base64 32
# Used by src/lib/crypto/payment-details.ts (Web Crypto AES-256-GCM) to
# encrypt seller bank account numbers at rest. NEVER commit a real key.
PAYMENT_DETAILS_ENCRYPTION_KEY=
